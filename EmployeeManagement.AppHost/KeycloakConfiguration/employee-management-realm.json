{
  "realm": "employee-management",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full administrative access"
      },
      {
        "name": "manager",
        "description": "Manager-level access to employee data"
      },
      {
        "name": "employee",
        "description": "Standard employee access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "employee-management-api",
      "name": "Employee Management API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "employee-management-api-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@employee-management.local",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "manager",
      "email": "manager@employee-management.local",
      "firstName": "Manager",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "manager",
          "temporary": false
        }
      ],
      "realmRoles": ["manager"]
    },
    {
      "username": "employee",
      "email": "employee@employee-management.local",
      "firstName": "Employee",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "employee",
          "temporary": false
        }
      ],
      "realmRoles": ["employee"]
    }
  ]
}
